{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sazaan-digital-web",
  "main": "scripts/worker.js",
  "compatibility_date": "2024-04-03",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
